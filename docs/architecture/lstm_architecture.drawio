                <mxCell id="a7" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#9673a6;" parent="1" source="output" target="compile" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
