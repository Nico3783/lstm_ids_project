<?xml version="1.0" encoding="UTF-8"?>
<!--
  docs/architecture/data_flow_diagram.drawio
  Project : Deep Learning IDS Using LSTM
  Purpose : Detailed data flow diagram showing how data is
            transformed at each pipeline stage.
  Tool    : draw.io — open with https://app.diagrams.net
  Chapter : 3 — Materials and Methods, Section 3.5
-->
<mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1"
              tooltips="1" connect="1" arrows="1" fold="1" page="1"
              pageScale="1" pageWidth="850" pageHeight="1100"
              math="0" shadow="0">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>

    <!-- TITLE -->
    <mxCell id="title" value="Data Flow Diagram — LSTM IDS Pipeline"
            style="text;html=1;strokeColor=none;fillColor=none;align=center;
                   fontSize=15;fontStyle=1;"
            vertex="1" parent="1">
      <mxGeometry x="125" y="20" width="600" height="35" as="geometry"/>
    </mxCell>

    <!-- ── Stage boxes (left-aligned vertical flow) ── -->

    <!-- Stage 1 -->
    <mxCell id="s1" value="&lt;b&gt;Stage 1 — Raw Dataset Files&lt;/b&gt;&#xa;NSL-KDD: KDDTrain+.txt / KDDTest+.txt&#xa;CICIDS2017: 8 daily CSV files&#xa;UNSW-NB15: training + testing CSV&#xa;&#xa;Format: headerless CSV / CSV with header"
            style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;
                   strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=8;"
            vertex="1" parent="1">
      <mxGeometry x="175" y="70" width="500" height="80" as="geometry"/>
    </mxCell>

    <!-- Arrow 1→2 -->
    <mxCell id="a1" style="edgeStyle=orthogonalEdgeStyle;"
            edge="1" source="s1" target="s2" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="a1l" value="src/data/loaders.py" style="edgeLabel;fontSize=9;
            fontStyle=2;align=center;verticalAlign=bottom;"
            vertex="1" connectable="0" parent="a1">
      <mxGeometry relative="0.5" as="geometry"/>
    </mxCell>

    <!-- Stage 2 -->
    <mxCell id="s2" value="&lt;b&gt;Stage 2 — Loaded DataFrame&lt;/b&gt;&#xa;Shape: (N, 43) for NSL-KDD (41 features + label + difficulty)&#xa;• Column names assigned from NSL_KDD_COLUMNS constant&#xa;• All dtypes preserved as loaded (str / float)&#xa;• Validation report generated (CheckResult per check)"
            style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;
                   strokeColor=#82b366;fontSize=10;align=left;spacingLeft=8;"
            vertex="1" parent="1">
      <mxGeometry x="175" y="195" width="500" height="80" as="geometry"/>
    </mxCell>

    <!-- Arrow 2→3 -->
    <mxCell id="a2" style="edgeStyle=orthogonalEdgeStyle;"
            edge="1" source="s2" target="s3" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="a2l" value="src/data/preprocessing.py" style="edgeLabel;fontSize=9;
            fontStyle=2;align=center;verticalAlign=bottom;"
            vertex="1" connectable="0" parent="a2">
      <mxGeometry relative="0.5" as="geometry"/>
    </mxCell>

    <!-- Stage 3 -->
    <mxCell id="s3" value="&lt;b&gt;Stage 3 — Cleaned DataFrame&lt;/b&gt;&#xa;• difficulty column dropped&#xa;• Missing values imputed (mean=continuous, mode=categorical)&#xa;• Infinite values replaced with NaN → imputed&#xa;• Duplicate rows removed&#xa;Saved: data/interim/cleaned_dataset.csv"
            style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;
                   strokeColor=#82b366;fontSize=10;align=left;spacingLeft=8;"
            vertex="1" parent="1">
      <mxGeometry x="175" y="325" width="500" height="85" as="geometry"/>
    </mxCell>

    <!-- Arrow 3→4 -->
    <mxCell id="a3" style="edgeStyle=orthogonalEdgeStyle;"
            edge="1" source="s3" target="s4" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="a3l" value="map_nsl_kdd_labels() + encode_categorical_features()"
            style="edgeLabel;fontSize=9;fontStyle=2;align=center;verticalAlign=bottom;"
            vertex="1" connectable="0" parent="a3">
      <mxGeometry relative="0.5" as="geometry"/>
    </mxCell>

    <!-- Stage 4 -->
    <mxCell id="s4" value="&lt;b&gt;Stage 4 — Encoded DataFrame&lt;/b&gt;&#xa;• Raw attack labels → 5-class integers (0=Normal, 1=DoS, 2=Probe, 3=R2L, 4=U2R)&#xa;• One-hot encoding: protocol_type (3), service (70), flag (11) → ~84 new columns&#xa;• Final feature count: 41 columns (NSL-KDD specification)&#xa;Saved: data/interim/encoded_dataset.csv"
            style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;
                   strokeColor=#d6b656;fontSize=10;align=left;spacingLeft=8;"
            vertex="1" parent="1">
      <mxGeometry x="175" y="460" width="500" height="85" as="geometry"/>
    </mxCell>

    <!-- Arrow 4→5 -->
    <mxCell id="a4" style="edgeStyle=orthogonalEdgeStyle;"
            edge="1" source="s4" target="s5" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="a4l" value="fit_scaler(X_train) → apply_scaler(X_all)"
            style="edgeLabel;fontSize=9;fontStyle=2;align=center;verticalAlign=bottom;"
            vertex="1" connectable="0" parent="a4">
      <mxGeometry relative="0.5" as="geometry"/>
    </mxCell>

    <!-- Stage 5 -->
    <mxCell id="s5" value="&lt;b&gt;Stage 5 — Scaled Feature Matrix  +  Label Vector&lt;/b&gt;&#xa;X: ndarray (N, 41), dtype=float32, range=[0.0, 1.0]&#xa;y: ndarray (N,),  dtype=int64,   values={0,1,2,3,4}&#xa;MinMaxScaler fitted on training split ONLY (no data leakage)&#xa;Saved: data/interim/scaled_dataset.csv"
            style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;
                   strokeColor=#d6b656;fontSize=10;align=left;spacingLeft=8;"
            vertex="1" parent="1">
      <mxGeometry x="175" y="596" width="500" height="85" as="geometry"/>
    </mxCell>

    <!-- Arrow 5→6 -->
    <mxCell id="a5" style="edgeStyle=orthogonalEdgeStyle;"
            edge="1" source="s5" target="s6" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="a5l" value="build_sequences(window=10, step=1, label='last')"
            style="edgeLabel;fontSize=9;fontStyle=2;align=center;verticalAlign=bottom;"
            vertex="1" connectable="0" parent="a5">
      <mxGeometry relative="0.5" as="geometry"/>
    </mxCell>

    <!-- Stage 6 -->
    <mxCell id="s6" value="&lt;b&gt;Stage 6 — 3-D Sequence Tensor&lt;/b&gt;&#xa;X_seq: ndarray (N-9, 10, 41), dtype=float32&#xa;y_seq: ndarray (N-9,),       dtype=int64&#xa;Each sequence: 10 consecutive traffic records&#xa;Label = class of final (10th) timestep"
            style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;
                   strokeColor=#d79b00;fontSize=10;align=left;spacingLeft=8;"
            vertex="1" parent="1">
      <mxGeometry x="175" y="733" width="500" height="80" as="geometry"/>
    </mxCell>

    <!-- Arrow 6→7 -->
    <mxCell id="a6" style="edgeStyle=orthogonalEdgeStyle;"
            edge="1" source="s6" target="s7" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="a6l" value="split_sequences(train=0.70, val=0.15, test=0.15, stratified=True)"
            style="edgeLabel;fontSize=9;fontStyle=2;align=center;verticalAlign=bottom;"
            vertex="1" connectable="0" parent="a6">
      <mxGeometry relative="0.5" as="geometry"/>
    </mxCell>

    <!-- Stage 7 -->
    <mxCell id="s7" value="&lt;b&gt;Stage 7 — Stratified Split Arrays&lt;/b&gt;&#xa;X_train (70%): (N₁, 10, 41)   y_train: (N₁,)&#xa;X_val   (15%): (N₂, 10, 41)   y_val  : (N₂,)&#xa;X_test  (15%): (N₃, 10, 41)   y_test : (N₃,)&#xa;Saved: data/processed/*.npy  |  Artifacts: scaler.pkl, label_encoder.pkl"
            style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;
                   strokeColor=#9673a6;fontSize=10;align=left;spacingLeft=8;"
            vertex="1" parent="1">
      <mxGeometry x="175" y="863" width="500" height="85" as="geometry"/>
    </mxCell>

    <!-- Arrow 7→8 -->
    <mxCell id="a7" style="edgeStyle=orthogonalEdgeStyle;"
            edge="1" source="s7" target="s8" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="a7l" value="model.fit(X_train, y_train_onehot, class_weight=...)"
            style="edgeLabel;fontSize=9;fontStyle=2;align=center;verticalAlign=bottom;"
            vertex="1" connectable="0" parent="a7">
      <mxGeometry relative="0.5" as="geometry"/>
    </mxCell>

    <!-- Stage 8 -->
    <mxCell id="s8" value="&lt;b&gt;Stage 8 — Trained LSTM Model + Evaluation Reports&lt;/b&gt;&#xa;Saved: models/final/lstm_ids_model.keras&#xa;Metrics: Accuracy, Precision (macro+wtd), Recall, F1, ROC-AUC&#xa;Figures: confusion_matrix.png, roc_curve.png, training_curves.png&#xa;Tables: final_metrics.csv, baseline_metrics.csv"
            style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;
                   strokeColor=#b85450;fontSize=10;align=left;spacingLeft=8;"
            vertex="1" parent="1">
      <mxGeometry x="175" y="1000" width="500" height="85" as="geometry"/>
    </mxCell>

  </root>
</mxGraphModel>
